{
  "name": "@ai-first/nextjs",
  "version": "0.1.0",
  "description": "AI-First Framework - Spring Boot style HTTP decorators and Express router",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./express": {
      "import": "./dist/express-router.js",
      "types": "./dist/express-router.d.ts"
    },
    "./client-lite": {
      "import": "./dist/client-lite.js",
      "types": "./dist/client-lite.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "reflect-metadata": "^0.2.1",
    "@ai-first/core": "workspace:*",
    "@ai-first/di": "workspace:*",
    "@ai-first/orm": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "express": "^4.18.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "ai-first",
    "express",
    "spring-boot",
    "rest-api",
    "controller",
    "decorators",
    "typescript"
  ]
}
