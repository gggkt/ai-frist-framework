{
  "name": "@scaffold/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./client": {
      "import": "./dist/client/index.ts",
      "types": "./dist/client/index.ts"
    }
  },
  "scripts": {
    "dev": "pnpm dev:dev",
    "dev:dev": "cross-env APP_ENV=dev NODE_ENV=development concurrently -n codegen,server -c blue,green \"pnpm codegen:watch\" \"node --import @swc-node/register/esm-register --watch src/server.ts\"",
    "dev:stage": "cross-env APP_ENV=stage NODE_ENV=production concurrently -n codegen,server -c blue,green \"pnpm codegen:watch\" \"node --import @swc-node/register/esm-register --watch src/server.ts\"",
    "dev:prod": "cross-env APP_ENV=prod NODE_ENV=production concurrently -n codegen,server -c blue,green \"pnpm codegen:watch\" \"node --import @swc-node/register/esm-register --watch src/server.ts\"",
    "dev:server": "node --import @swc-node/register/esm-register --watch src/server.ts",
    "codegen:watch": "node scripts/codegen.cjs --watch",
    "init-db": "node --import @swc-node/register/esm-register src/scripts/init-db.ts",
    "codegen": "node scripts/codegen.cjs",
    "build": "pnpm codegen && tsup",
    "start": "cross-env APP_ENV=prod NODE_ENV=production node dist/server.js",
    "start:dev": "cross-env APP_ENV=dev NODE_ENV=development node dist/server.js",
    "start:stage": "cross-env APP_ENV=stage NODE_ENV=production node dist/server.js",
    "start:prod": "cross-env APP_ENV=prod NODE_ENV=production node dist/server.js",
    "lint": "eslint src"
  },
  "dependencies": {
    "@ai-partner-x/aiko-boot": "workspace:*",
    "@ai-partner-x/aiko-boot-codegen": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-orm": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-validation": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-web": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-security": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-log": "workspace:*",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^4.18.0",
    "axios": "^1.6.0",
    "reflect-metadata": "^0.2.1",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "sql.js": "^1.11.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}

