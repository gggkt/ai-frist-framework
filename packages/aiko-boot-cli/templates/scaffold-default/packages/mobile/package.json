{
  "name": "@scaffold/mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev --port 3002",
    "dev:dev": "vite --mode dev --port 3002",
    "dev:stage": "vite --mode stage --port 3002",
    "dev:prod": "vite --mode prod --port 3002",
    "build": "pnpm build:prod",
    "build:dev": "tsc --noEmit && vite build --mode dev",
    "build:stage": "tsc --noEmit && vite build --mode stage",
    "build:prod": "tsc --noEmit && vite build --mode prod",
    "preview": "vite preview",
    "lint": "eslint src"
  },
  "dependencies": {
    "@scaffold/core": "workspace:*",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^20",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
