# copy this file to .env.dev/.env.stage/.env.prod and fill secure values
NODE_ENV=development
APP_ENV=dev
PORT=3001

# security
JWT_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
SESSION_SECRET=replace-me

# cors
CORS_ORIGIN=http://localhost:4200,http://localhost:3002

# cache
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

