{
  "name": "scaffold-monorepo",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"@scaffold/api\" --filter \"@scaffold/admin\" --filter \"@scaffold/mobile\" dev",
    "dev:stage": "pnpm -r --parallel --filter \"@scaffold/api\" --filter \"@scaffold/admin\" --filter \"@scaffold/mobile\" dev:stage",
    "dev:prod": "pnpm -r --parallel --filter \"@scaffold/api\" --filter \"@scaffold/admin\" --filter \"@scaffold/mobile\" dev:prod",
    "build": "pnpm -r --parallel --filter \"@scaffold/api\" --filter \"@scaffold/admin\" --filter \"@scaffold/mobile\" build",
    "start:api": "pnpm -F @scaffold/api start",
    "init-db": "pnpm -F @scaffold/api init-db",
    "rebuild:sqlite": "node ./scripts/rebuild-sqlite.cjs",
    "lint": "pnpm -r --parallel --filter \"@scaffold/api\" --filter \"@scaffold/admin\" --filter \"@scaffold/mobile\" lint"
  },
  "postinstall": "node ./scripts/postinstall.cjs",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "typescript": "^5.3.0"
  }
}
