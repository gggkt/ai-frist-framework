# scaffold/admin 环境模板
# 用法：复制为 .env.<mode>（如 .env.dev/.env.stage/.env.prod）后，填写真实地址与回调信息。

APP_ENV=dev

# 未授权时 redirect 的登录地址。
# 建议保持为前端内部路径 /login（admin 内已有该路由），若使用外部 SSO 则改为完整 URL。
VITE_APP_LOGIN=/login

# 后端 API Base URL（不包含 /api 前缀）
VITE_API_URL=http://localhost:3001

# Vite dev server 代理目标（用于将前端请求的 /api 转发到后端）
VITE_API_PROXY_TARGET=http://localhost:3001

# 是否启用前端守卫（需要根据自身鉴权策略调整）
VITE_APP_USE_GUARD=false

