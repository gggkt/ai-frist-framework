{
  "name": "@ai-partner-x/aiko-boot-cli",
  "version": "0.1.5",
  "description": "CLI to create aiko-boot scaffold project (monorepo with api, admin, mobile, shared)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aiko-boot": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "sync:templates:api-system": "node ./scripts/sync-api-system.mjs",
    "sync:templates:api-system:dry": "node ./scripts/sync-api-system.mjs --dry-run",
    "sync:templates:api-clean": "node ./scripts/sync-api-clean.mjs",
    "sync:templates:api-clean:dry": "node ./scripts/sync-api-clean.mjs --dry-run",
    "sync:templates:apps": "node ./scripts/sync-app-templates.mjs",
    "sync:templates:apps:dry": "node ./scripts/sync-app-templates.mjs --dry-run"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
