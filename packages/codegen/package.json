{
  "name": "@ai-first/codegen",
  "version": "0.1.0",
  "description": "TypeScript to Java code generator for AI-First Framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
